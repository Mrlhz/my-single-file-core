{
  "name": "my-single-file",
  "version": "0.1.0",
  "description": "A modular single-file web page archiver for browser extensions",
  "type": "module",
  "main": "./dist/my-single-file.umd.js",
  "module": "./dist/my-single-file.es.js",
  "unpkg": "./dist/my-single-file.umd.js",
  "jsdelivr": "./dist/my-single-file.umd.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/my-single-file.es.js",
      "require": "./dist/my-single-file.umd.js"
    }
  },
  "browser": "./dist/my-single-file.umd.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && npm run copy:examples", 
    "copy:examples": "node scripts/copy-examples.js",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "css-tree": "^3.2.1"
  }
}
